<Window x:Class="CrudStudy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrudStudy"
        mc:Ignorable="d"
        Title="CRUD Study" Height="650" Width="850">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 좌측: 게시글 목록 -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <Button DockPanel.Dock="Top"
                    Content="전체 조회 (GET)"
                    Command="{Binding GetAllCommand}"
                    Padding="10,5"
                    Margin="0,0,0,10"/>
            <ListView ItemsSource="{Binding Posts}"
                      SelectedItem="{Binding SelectedPost}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="40"
                                        DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Title" Width="400"
                                        DisplayMemberBinding="{Binding Title}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!-- 우측: 상세/입력 영역 -->
        <DockPanel Grid.Column="1">
            <!-- 하단 버튼들 -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Button Content="작성 (POST)"
                        Command="{Binding CreateCommand}"
                        Padding="10,5"
                        Margin="0,0,0,5"/>
                <Button Content="수정 (PUT)"
                        Command="{Binding UpdateCommand}"
                        Padding="10,5"
                        Margin="0,0,0,5"/>
                <Button Content="삭제 (DELETE)"
                        Command="{Binding DeleteCommand}"
                        Padding="10,5"/>
            </StackPanel>

            <!-- 입력 폼 -->
            <StackPanel>
                <TextBlock Text="ID" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditId, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         Background="#F0F0F0"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Title" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Body" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditBody, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Height="200"
                         Margin="0,0,0,10"/>

                <TextBlock Text="결과" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBox Text="{Binding StatusMessage}"
                         IsReadOnly="True"
                         Background="#F5F5F5"
                         TextWrapping="Wrap"
                         Height="140"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
